{
  "expo": {
    "name": "AllerLens",
    "slug": "allerlens",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.allerlens.app"
    },
    "android": {
      "package": "com.allerlens.app",
      "adaptiveIcon": {
        "backgroundColor": "#F8F4EB"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "AllerLens needs camera access to scan ingredient labels."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "AllerLens needs photo library access to upload ingredient images.",
          "cameraPermission": "AllerLens needs camera access to scan ingredient labels."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b462d12e-12b0-4938-84b2-518492f969df"
      }
    }
  }
}
